import time
from azure.core.exceptions import ResourceNotFoundError, HttpResponseError

MAX_SIZE_BYTES = 50 * 1024 * 1024  # 50 MB

def directory_exists_and_has_data(file_path, file_system_client, retries=3, wait=10, timeout=60):
    """
    Check if directory exists and contains valid Avro/Parquet data files.
    Retries only on transient errors (timeouts, network issues).
    Skips retry if the directory/blob truly doesn't exist.
    """
    for attempt in range(1, retries + 1):
        try:
            # Ensure directory exists
            directory_client = file_system_client.get_directory_client(file_path)
            directory_client.get_directory_properties(timeout=timeout)

            # List all files recursively
            paths = list(file_system_client.get_paths(path=file_path, recursive=True, timeout=timeout))
            if not paths:
                return "EMPTY_DIRECTORY"

            for file in paths:
                if not file.is_directory and (file.name.endswith(".avro") or file.name.endswith(".parquet")):
                    if file.content_length > 0:
                        # Skip record check if file size > 50 MB
                        if file.content_length > MAX_SIZE_BYTES:
                            return "FILE_FOUND"

                        file_client = file_system_client.get_file_client(file.name)

                        if file.name.endswith(".avro") and avro_has_records_stream(file_client):
                            return "FILE_FOUND"

                        if file.name.endswith(".parquet") and parquet_has_records_stream(file_client):
                            return "FILE_FOUND"

            return "ZERO_RECORD_FILE"

        except ResourceNotFoundError as e:
            # Hard fail: directory/blob does not exist
            print(f"[ERROR] Path not found: {file_path} | {e}")
            return "PARTITION_NOT_FOUND"

        except HttpResponseError as e:
            # Skip retry if it's a 404 error
            if "The specified blob does not exist" in str(e):
                print(f"[ERROR] Blob not found: {file_path} | {e}")
                return "PARTITION_NOT_FOUND"
            else:
                print(f"[WARN] Attempt {attempt}/{retries} failed for {file_path} | {e}")
                if attempt < retries:
                    time.sleep(wait)
                else:
                    print(f"[ERROR] Directory check failed after {retries} attempts: {file_path}")
                    return "PARTITION_NOT_FOUND"

        except Exception as e:
            # Generic transient error (retryable)
            print(f"[WARN] Attempt {attempt}/{retries} failed for {file_path} | {e}")
            if attempt < retries:
                time.sleep(wait)
            else:
                print(f"[ERROR] Directory check failed after {retries} attempts: {file_path}")
                return "PARTITION_NOT_FOUND"
