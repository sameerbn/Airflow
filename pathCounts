%livy2.pyspark
from datetime import datetime, timedelta
import numpy as np

base_path = "abfss://lake@...../your_table"  # change this to your base path

# Define your custom start date here (yyyyMMdd format)
start_date_str = "20250815"   # 👈 change this
start_date = datetime.strptime(start_date_str, "%Y%m%d")

# How many past same-weekdays you want
N = 6   # e.g., last 6 Fridays if start_date is a Friday

# Generate last N same-weekdays (including start_date)
dates = [(start_date - timedelta(weeks=i)).strftime("%Y%m%d") for i in range(N)]

counts = []
for d in dates:
    path = f"{base_path}/dt={d}"   # adjust "dt=" if your partition key is different
    try:
        df = spark.read.parquet(path)
        counts.append(df.count())
    except Exception:
        # skip missing partitions
        pass

# Show counts in reverse date order (latest → oldest)
print("Historical counts (latest first):")
for c in counts:
    print(c)

# --- Prediction excluding outliers ---
if counts:
    arr = np.array(counts)

    # Compute IQR for outlier detection
    Q1 = np.percentile(arr, 25)
    Q3 = np.percentile(arr, 75)
    IQR = Q3 - Q1
    lower_bound = Q1 - 1.5 * IQR
    upper_bound = Q3 + 1.5 * IQR

    # Filter outliers
    filtered = arr[(arr >= lower_bound) & (arr <= upper_bound)]

    if len(filtered) > 0:
        prediction = int(filtered.mean())
        print("\nPredicted next count (excluding outliers):", prediction)
    else:
        print("\nPrediction not possible (all values treated as outliers).")
else:
    print("No counts found.")
