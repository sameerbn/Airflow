%livy2.pyspark
from pyspark.sql import SparkSession
from pyspark.sql.types import *
from datetime import datetime, timedelta

base_path = "abfss://lake@...../your_table"  # change this to your table base path

# Generate past 30 days (yyyy-MM-dd format, adjust to your partition style)
dates = [(datetime.today() - timedelta(days=i)).strftime("%Y-%m-%d") for i in range(30)]

results = []
for d in dates:
    path = f"{base_path}/dt={d}"   # adjust partition key (dt=, date=, storageday=, etc.)
    try:
        df = spark.read.parquet(path)
        cnt = df.count()
        results.append((d, cnt))
    except Exception:
        # skip missing partitions silently
        pass

# Create dataframe for display
schema = StructType([
    StructField("date", StringType(), True),
    StructField("record_count", LongType(), True)
])
df_out = spark.createDataFrame(results, schema)

df_out.orderBy("date").show(30, False)
